# Base API URL — include /api/v1 suffix
BASE_URL=https://your-backend.railway.app/api/v1

# WebSocket URL — use wss:// in production
WS_URL=wss://your-backend.railway.app/ws

# Invite deep-link base
INVITE_BASE_URL=https://mapilm.app/invite

# Firebase (from google-services.json / GoogleService-Info.plist)
FIREBASE_ANDROID_API_KEY=
FIREBASE_IOS_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Optional: AES encryption key for local storage (32 hex chars)
ENCRYPTION_KEY=
