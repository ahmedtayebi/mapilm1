# ══════════════════════════════════════════════════════════════════════════════
# mapilm_backend — Django / Python .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Secrets (NEVER commit) ──────────────────────────────────────────────────
.env
.env.*
!.env.example
firebase-credentials.json
firebase_credentials.json
service-account*.json

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editors ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.history/

# ── Python bytecode ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.python-version

# ── Django ───────────────────────────────────────────────────────────────────
staticfiles/
media/
db.sqlite3
*.sqlite3
local_settings.py

# ── Celery ───────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Testing & Coverage ────────────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
pip-wheel-metadata/

# ── Type checkers & linters ───────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
