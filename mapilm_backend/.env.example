# # ── Django ────────────────────────────────────────────────────────────────────
# SECRET_KEY=your-secret-key-here-use-django-get-random-secret-key
# DEBUG=False
# ALLOWED_HOSTS=your-app.railway.app,your-custom-domain.com
# CORS_ALLOWED_ORIGINS=https://your-app.railway.app

# # ── Database (Railway provides DATABASE_URL automatically) ────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/mapilm

# # ── Redis (Railway provides REDIS_URL automatically) ──────────────────────────
# REDIS_URL=redis://default:password@host:6379

# # ── Firebase Admin SDK ────────────────────────────────────────────────────────
# # Copy the entire JSON from: Firebase Console → Project Settings → Service Accounts
# # → Generate new private key. Paste as a single-line JSON string.
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# # ── Cloudinary ────────────────────────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# # ── App URLs ──────────────────────────────────────────────────────────────────
# FLUTTER_BASE_URL=https://your-app.railway.app
# INVITE_BASE_URL=https://mapilm.app/invite

# # ── JWT (optional overrides) ──────────────────────────────────────────────────
# ACCESS_TOKEN_LIFETIME_DAYS=1
# REFRESH_TOKEN_LIFETIME_DAYS=30
